# GitHub token (optional — copilot-flow uses your logged-in gh CLI by default)
# Only needed if you want to override the authenticated user
GITHUB_TOKEN=ghp_your_token_here

# copilot-flow configuration overrides
COPILOT_FLOW_LOG_LEVEL=info
COPILOT_FLOW_DEFAULT_MODEL=gpt-4o
COPILOT_FLOW_MAX_RETRIES=3
COPILOT_FLOW_RETRY_DELAY_MS=1000
