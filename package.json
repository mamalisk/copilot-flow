{
  "name": "copilot-flow",
  "version": "2.0.0",
  "description": "Multi-agent orchestration framework for GitHub Copilot CLI — inspired by Ruflo (claude-flow)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "copilot-flow": "./bin/copilot-flow.js"
  },
  "files": [
    "dist/",
    "bin/",
    "copilot-flow.png"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "github-copilot",
    "copilot",
    "multi-agent",
    "ai",
    "swarm",
    "orchestration",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "latest",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
