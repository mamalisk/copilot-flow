{
  "name": "copilot-flow",
  "version": "2.16.0",
  "description": "Multi-agent orchestration framework for GitHub Copilot CLI — inspired by Ruflo (claude-flow)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "copilot-flow": "./bin/copilot-flow.js"
  },
  "files": [
    "dist/",
    "bin/",
    "copilot-flow.png"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-tui.mjs",
    "prepublishOnly": "npm run build",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "github-copilot",
    "copilot",
    "multi-agent",
    "ai",
    "swarm",
    "orchestration",
    "cli"
  ],
  "author": "Kostas Mamalis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mamalisk/copilot-flow.git"
  },
  "homepage": "https://github.com/mamalisk/copilot-flow#readme",
  "bugs": {
    "url": "https://github.com/mamalisk/copilot-flow/issues"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.3.0-preview.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "ink": "^7.0.1",
    "js-yaml": "^4.1.1",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "ora": "^8.1.1",
    "react": "^19.2.5",
    "react-devtools-core": "7.0.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
